---
import type { ResolvedTag } from '@/types'

export interface Props {
  tags: ResolvedTag[]
}

const { tags } = Astro.props
---

<div class="flex flex-wrap gap-x-6 gap-y-3 text-base">
  {
    tags.map(({ tag, icon }) => (
      <a
        class="clickable inline-flex items-center gap-1 no-underline"
        href={`/tags/${tag}/`}
      >
        <span class={`iconify text-xl ${icon}`} />
        <span class="font-normal">{tag}</span>
      </a>
    ))
  }
</div>
