{
  "name": "nordlys",
  "type": "module",
  "version": "3.8.0",
  "description": "A minimal Astro blog theme",
  "author": "FjellOverflow",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/FjellOverflow/nordlys",
  "repository": {
    "type": "git",
    "url": "https://github.com/FjellOverflow/nordlys.git"
  },
  "bugs": {
    "url": "https://github.com/FjellOverflow/nordlys/issues"
  },
  "keywords": [
    "astro",
    "blog",
    "template",
    "theme",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "astro dev",
    "lint": "eslint . && stylelint src",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "release": "commit-and-tag-version --sign",
    "postbuild": "pagefind --site dist",
    "test": "playwright test",
    "test:regenerate": "rm -rf test/snapshots && playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@iconify-json/simple-icons": "^1.2.86",
    "@iconify-json/tabler": "^1.2.35",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.5",
    "astro-expressive-code": "^0.41.7",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "photoswipe-dynamic-caption-plugin": "^1.2.7",
    "photoswipe-thumbs-plugin": "^1.1.3",
    "reading-time": "^1.5.0",
    "remark-sectionize": "^2.1.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/parser": "^8.61.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "stylelint": "^17.13.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "packageManager": "pnpm@11.5.1"
}
