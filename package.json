{
  "name": "nordlys",
  "type": "module",
  "version": "3.9.1",
  "description": "A minimal Astro blog theme",
  "author": "FjellOverflow",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/FjellOverflow/nordlys",
  "repository": {
    "type": "git",
    "url": "https://github.com/FjellOverflow/nordlys.git"
  },
  "bugs": {
    "url": "https://github.com/FjellOverflow/nordlys/issues"
  },
  "keywords": [
    "astro",
    "blog",
    "template",
    "theme",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "astro dev",
    "lint": "eslint . && stylelint src",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "release": "commit-and-tag-version --sign",
    "postbuild": "pagefind --site dist",
    "test": "playwright test",
    "test:regenerate": "rm -rf test/snapshots && playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@iconify-json/simple-icons": "^1.2.90",
    "@iconify-json/tabler": "^1.2.35",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "astro-expressive-code": "^0.44.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "photoswipe-dynamic-caption-plugin": "^1.2.7",
    "photoswipe-thumbs-plugin": "^1.1.3",
    "reading-time": "^1.5.0",
    "remark-sectionize": "^2.1.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@eslint/js": "^10.0.1",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/parser": "^8.64.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@11.13.0"
}
