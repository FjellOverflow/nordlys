{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "typeRoots": [
        "./src/types",
        "./node_modules/@types"
      ],
    }
  },
  "exclude": [
    "dist"
  ]
}